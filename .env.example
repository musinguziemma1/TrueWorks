# ============================================================
# PUBLIC ENVIRONMENT VARIABLES (Safe to expose in client bundle)
# ============================================================
# These are prefixed with VITE_ and are visible to anyone using
# browser dev-tools. NEVER put secrets here.
# ============================================================

# Convex deployment URL (safe to expose — all writes go through
# your Convex backend, which enforces auth / authorization)
VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Analytics
VITE_GA_ID=G-XXXXXXXXXX
VITE_FB_PIXEL=YOUR_PIXEL_ID

# ============================================================
# SERVER-ONLY SECRETS (Set via `npx convex env set`)
# ============================================================
# These are stored server-side and NEVER exposed to the browser.
# Example: `npx convex env set PESAPAL_CONSUMER_KEY "your_key"`
# ============================================================

# Pesapal — payment gateway keys stay on the Convex backend.
# Get sandbox keys at https://developer.pesapal.com
PESAPAL_CONSUMER_KEY=your_consumer_key
PESAPAL_CONSUMER_SECRET=your_consumer_secret
PESAPAL_IPN_ID=your_pesapal_ipn_id
PESAPAL_ENV=sandbox  # "sandbox" or "live"
PESAPAL_IPN_URL=https://your-deployment.convex.site/api/pesapal/ipn

# Download token signing secret (rotate periodically)
# Generate with: openssl rand -hex 32
DOWNLOAD_TOKEN_SECRET=replace-me-with-a-32-byte-random-hex-string

# Resend (transactional email)
# Get API key at https://resend.com
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=orders@yourdomain.com
SITE_URL=https://yourdomain.com

# Optional: Sentry for error tracking
SENTRY_DSN=

# Optional: NVIDIA AI API key (used by /api/ai endpoints)
NVIDIA_API_KEY=nvapi-your-key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=z-ai/glm-5.2
